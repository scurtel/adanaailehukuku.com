---
interface Props {
  title: string;
  href: string;
  desc: string;
  image: string;
  imageAlt: string;
  /** Above-the-fold cards: eager load; first card may also get high fetch priority. */
  priority?: boolean;
  fetchPriorityHigh?: boolean;
}

const { title, href, desc, image, imageAlt, priority = false, fetchPriorityHigh = false } = Astro.props;
---

<article class="card service-card">
  <div class="service-card__media">
    <img
      src={image}
      alt={imageAlt}
      width="800"
      height="533"
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      fetchpriority={fetchPriorityHigh ? 'high' : undefined}
      referrerpolicy="no-referrer"
    />
  </div>
  <div class="service-card__body">
    <h3><a href={href}>{title}</a></h3>
    <p>{desc}</p>
    <a class="service-card__link" href={href}>Detaylı bilgi →</a>
  </div>
</article>

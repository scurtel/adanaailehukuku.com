---
import { NAV_ITEMS, SITE_NAME } from '../consts';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h3>{SITE_NAME}</h3>
      <p>Adana'da aile hukuku, boşanma, velayet, nafaka ve mal paylaşımı alanında hukuki danışmanlık.</p>
    </div>
    <div>
      <h3>Hizmetler</h3>
      <ul>
        <li><a href="/adana-aile-hukuku-avukati/">Aile Hukuku</a></li>
        <li><a href="/adana-bosanma-avukati/">Boşanma</a></li>
        <li><a href="/adana-velayet-davasi-avukati/">Velayet</a></li>
        <li><a href="/adana-nafaka-davasi-avukati/">Nafaka</a></li>
      </ul>
    </div>
    <div>
      <h3>Site</h3>
      <ul>
        {NAV_ITEMS.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© {new Date().getFullYear()} {SITE_NAME}. Tüm hakları saklıdır. Bu site genel bilgilendirme amaçlıdır.</p>
  </div>
</footer>

---
import { NAV_ITEMS, SITE_NAME } from '../consts';
import FooterNap from './FooterNap.astro';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h3>{SITE_NAME}</h3>
      <p>Adana'da aile hukuku, boşanma, velayet, nafaka ve mal paylaşımı alanında hukuki danışmanlık.</p>
      <FooterNap />
    </div>
    <div>
      <h3>Hizmetler</h3>
      <ul>
        <li><a href="/adana-aile-hukuku-avukati/">Aile Hukuku</a></li>
        <li><a href="/adana-bosanma-avukati/">Adana boşanma avukatı</a></li>
        <li><a href="/adana-anlasmali-bosanma-avukati/">Anlaşmalı boşanma</a></li>
        <li><a href="/adana-cekismeli-bosanma-avukati/">Çekişmeli boşanma</a></li>
        <li><a href="/adana-velayet-davasi-avukati/">Velayet davası</a></li>
        <li><a href="/adana-nafaka-davasi-avukati/">Nafaka talepleri</a></li>
        <li><a href="/adana-mal-paylasimi-avukati/">Mal paylaşımı</a></li>
        <li><a href="/adana-ziynet-alacagi-avukati/">Ziynet alacağı</a></li>
        <li><a href="/aile-konutu-serhi-avukati/">Aile konutu şerhi</a></li>
        <li><a href="/uzaklastirma-karari-avukati/">Uzaklaştırma kararı</a></li>
        <li><a href="/adana-ilce-aile-hukuku-avukati/">Adana ilçeleri</a></li>
        <li><a href="/iletisim/">İletişim</a></li>
      </ul>
    </div>
    <div>
      <h3>Site</h3>
      <ul>
        {NAV_ITEMS.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
        <li><a href="/adana-ilce-aile-hukuku-avukati/">İlçe rehberi</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© {new Date().getFullYear()} {SITE_NAME}. Tüm hakları saklıdır. Bu site genel bilgilendirme amaçlıdır.</p>
  </div>
</footer>

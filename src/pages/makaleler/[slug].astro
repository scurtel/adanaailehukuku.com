---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection } from 'astro:content';
import { getArticleSlug } from '../../utils/content';
import {
  parseMarkdownBody,
  buildArticleSchema,
  buildBreadcrumbSchema,
  mergeSchemas,
} from '../../utils/markdown';
import {
  CANONICAL_ARTICLE_REPLACEMENTS,
  NOINDEX_ARTICLE_SLUGS,
  SITE_URL,
} from '../../consts';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => {
    const slug = getArticleSlug(article);
    return {
      params: { slug },
      props: { article },
    };
  });
}

const { article } = Astro.props;
const slug = getArticleSlug(article);
const path = `/makaleler/${slug}/`;
const noindex = NOINDEX_ARTICLE_SLUGS.has(slug);
const replacementSlug = CANONICAL_ARTICLE_REPLACEMENTS[slug];
const canonicalPath = replacementSlug ? `/makaleler/${replacementSlug}/` : undefined;
const { html, relatedLinks, schemas } = parseMarkdownBody(article.body ?? '');

const articleSchema = buildArticleSchema({
  title: article.data.title,
  description: article.data.description,
  slug,
  date: article.data.date,
  author: article.data.author,
});

const pageSchemas = mergeSchemas(
  schemas.length > 0 ? schemas : [articleSchema],
  [
    buildBreadcrumbSchema([
      { name: 'Ana Sayfa', url: `${SITE_URL}/` },
      { name: 'Makaleler', url: `${SITE_URL}/makaleler/` },
      { name: article.data.title, url: `${SITE_URL}${path}` },
    ]),
  ],
);

const breadcrumbs = [
  { label: 'Makaleler', href: '/makaleler/' },
  { label: article.data.title },
];

const canonicalNotice = replacementSlug
  ? {
      label: 'güncel makale',
      href: `/makaleler/${replacementSlug}/`,
    }
  : undefined;
---

<ContentLayout
  title={article.data.title}
  description={article.data.description}
  path={path}
  breadcrumbs={breadcrumbs}
  html={html}
  relatedLinks={relatedLinks}
  schemas={pageSchemas}
  ogType="article"
  category={article.data.category}
  focusKeyword={article.data.focusKeyword}
  secondaryKeywords={article.data.secondaryKeywords}
  author={article.data.author}
  reviewer={article.data.reviewer}
  practiceArea={article.data.practiceArea}
  location={article.data.location}
  publishedDate={article.data.date}
  noindex={noindex}
  canonicalPath={canonicalPath}
  canonicalNotice={canonicalNotice}
/>

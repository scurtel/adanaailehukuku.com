---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AttorneyBox from '../components/AttorneyBox.astro';
import CTA from '../components/CTA.astro';
import { SERVICE_CARDS } from '../consts';
import { getHomePage, getArticlesSorted } from '../utils/content';
import { parseMarkdownBody, buildLegalServiceSchema, buildLocalBusinessSchema, buildBreadcrumbSchema, buildPersonSchema, mergeSchemas, stripHomeDisplaySections } from '../utils/markdown';
import { NOINDEX_ARTICLE_SLUGS, SITE_URL } from '../consts';
import { getArticleSlug } from '../utils/content';

const home = await getHomePage();
if (!home) throw new Error('ana-sayfa.md bulunamadı');

const articles = await getArticlesSorted();
const recentArticles = articles
  .filter((a) => !NOINDEX_ARTICLE_SLUGS.has(getArticleSlug(a)))
  .slice(0, 6);

const rawBody = home.body ?? '';
const bodyForMeta = stripHomeDisplaySections(rawBody);

const faqSplit = bodyForMeta.split(/^## Sık Sorulan Sorular\s*$/m);
const mainContent = faqSplit[0] ?? bodyForMeta;
const faqContent = faqSplit[1]?.split(/^## /m)[0]?.trim() ?? '';

const { html: mainHtml } = parseMarkdownBody(mainContent);
const { html: faqHtml } = faqContent ? parseMarkdownBody(`## Sık Sorulan Sorular\n\n${faqContent}`) : { html: '' };
const { relatedLinks, schemas: contentSchemas } = parseMarkdownBody(bodyForMeta);

const pageSchemas = mergeSchemas(
  [buildLocalBusinessSchema(), buildPersonSchema()],
  contentSchemas.length > 0
    ? contentSchemas
    : [
        buildLegalServiceSchema({
          title: 'Adana Aile Hukuku Avukatı',
          description: home.data.description,
          path: '/',
        }),
      ],
  [
    buildBreadcrumbSchema([
      { name: 'Ana Sayfa', url: `${SITE_URL}/` },
    ]),
  ],
);
---

<BaseLayout
  title={home.data.title}
  description={home.data.description}
  path="/"
  schemas={pageSchemas}
>
  <section class="hero">
    <div class="container">
      <h1>Adana'da Aile Hukuku ve Boşanma Süreçlerinde Hukuki Destek</h1>
      <p>{home.data.description}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/iletisim/">Hukuki Danışmanlık Al</a>
        <a class="btn btn-secondary" href="/makaleler/">Makaleleri İncele</a>
      </div>
    </div>
  </section>

  <div class="container">
    <h2 class="section-title">Hizmetler</h2>
    <div class="grid-3 services-grid">
      {SERVICE_CARDS.map((card) => (
        <ServiceCard
          title={card.title}
          href={card.href}
          desc={card.desc}
          image={card.image}
          imageAlt={card.imageAlt}
        />
      ))}
    </div>

    <h2 class="section-title section-spaced">Son Makaleler</h2>
    <div class="grid-2">
      {recentArticles.map((article) => {
        const slug = article.data.slug ?? article.id.replace(/\.md$/, '');
        return (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/makaleler/${slug}/`}
            category={article.data.category}
            focusKeyword={article.data.focusKeyword}
            date={article.data.date}
          />
        );
      })}
    </div>

    <AttorneyBox />

    <section class="content-card section-spaced">
      <h2 class="section-title">Adana Boşanma ve Aile Hukuku Hizmetleri</h2>
      <p>
        Adana'da boşanma ve fer'î talepler için ayrıntılı bilgi alabileceğiniz hizmet sayfaları:
        <a href="/adana-bosanma-avukati/">Adana boşanma avukatı</a>,
        <a href="/adana-anlasmali-bosanma-avukati/">anlaşmalı boşanma süreci</a>,
        <a href="/adana-cekismeli-bosanma-avukati/">çekişmeli boşanma davası</a>,
        <a href="/adana-velayet-davasi-avukati/">velayet davası</a>,
        <a href="/adana-nafaka-davasi-avukati/">nafaka talepleri</a>,
        <a href="/adana-mal-paylasimi-avukati/">mal paylaşımı</a>
        ve <a href="/iletisim/">danışmanlık / iletişim</a>.
      </p>
    </section>

    <article class="content-card section-spaced">
      <div class="prose" set:html={mainHtml} />
    </article>

    {
      faqHtml && (
        <section class="content-card section-spaced" id="sss">
          <h2 class="section-title">Sık Sorulan Sorular</h2>
          <div class="prose" set:html={faqHtml} />
        </section>
      )
    }

    {
      relatedLinks.length > 0 && (
        <section class="related-section">
          <h2>İlgili İçerikler</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li>
                <a href={link.href}>{link.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <CTA />
  </div>
</BaseLayout>

<style>
  .section-spaced {
    margin-top: 2rem;
  }
</style>

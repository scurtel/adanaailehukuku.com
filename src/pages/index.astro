---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AttorneyBox from '../components/AttorneyBox.astro';
import CTA from '../components/CTA.astro';
import { SERVICE_CARDS } from '../consts';
import { getHomePage, getArticlesSorted } from '../utils/content';
import { parseMarkdownBody, buildLegalServiceSchema } from '../utils/markdown';

const home = await getHomePage();
if (!home) throw new Error('ana-sayfa.md bulunamadı');

const articles = await getArticlesSorted();
const recentArticles = articles.slice(0, 6);

let rawBody = home.body ?? '';
rawBody = rawBody.replace(/^## Hero[\s\S]*?(?=^## )/m, '');
rawBody = rawBody.replace(/^## Hizmetler[\s\S]*?(?=^## )/m, '');
rawBody = rawBody.replace(/^## Son makaleler[\s\S]*?(?=^## )/m, '');

const faqSplit = rawBody.split(/^## Sık Sorulan Sorular\s*$/m);
const mainContent = faqSplit[0] ?? rawBody;
const faqContent = faqSplit[1]?.split(/^## /m)[0]?.trim() ?? '';

const { html: mainHtml, relatedLinks, schemas } = parseMarkdownBody(mainContent);
const { html: faqHtml } = faqContent ? parseMarkdownBody(`## Sık Sorulan Sorular\n\n${faqContent}`) : { html: '' };

const pageSchemas =
  schemas.length > 0
    ? schemas
    : [
        buildLegalServiceSchema({
          title: 'Adana Aile Hukuku Avukatı',
          description: home.data.description,
          path: '/',
        }),
      ];
---

<BaseLayout
  title={home.data.title}
  description={home.data.description}
  path="/"
  schemas={pageSchemas}
>
  <section class="hero">
    <div class="container">
      <h1>Adana'da Aile Hukuku ve Boşanma Süreçlerinde Hukuki Destek</h1>
      <p>{home.data.description}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/iletisim/">Hukuki Danışmanlık Al</a>
        <a class="btn btn-secondary" href="/makaleler/">Makaleleri İncele</a>
      </div>
    </div>
  </section>

  <div class="container">
    <h2 class="section-title">Hizmetler</h2>
    <div class="grid-3 services-grid">
      {SERVICE_CARDS.map((card) => (
        <ServiceCard
          title={card.title}
          href={card.href}
          desc={card.desc}
          image={card.image}
          imageAlt={card.imageAlt}
        />
      ))}
    </div>

    <h2 class="section-title section-spaced">Son Makaleler</h2>
    <div class="grid-2">
      {recentArticles.map((article) => {
        const slug = article.data.slug ?? article.id.replace(/\.md$/, '');
        return (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/makaleler/${slug}/`}
            category={article.data.category}
            focusKeyword={article.data.focusKeyword}
            date={article.data.date}
          />
        );
      })}
    </div>

    <AttorneyBox />

    <article class="content-card section-spaced">
      <div class="prose" set:html={mainHtml} />
    </article>

    {
      faqHtml && (
        <section class="content-card section-spaced" id="sss">
          <h2 class="section-title">Sık Sorulan Sorular</h2>
          <div class="prose" set:html={faqHtml} />
        </section>
      )
    }

    {
      relatedLinks.length > 0 && (
        <section class="related-section">
          <h2>İlgili İçerikler</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li>
                <a href={link.href}>{link.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <CTA />
  </div>
</BaseLayout>

<style>
  .section-spaced {
    margin-top: 2rem;
  }
</style>
